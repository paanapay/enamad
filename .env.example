# Copy to .env and fill in. Used by docker-compose.

# --- MySQL ---
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=enamad

# --- Timezone ---
TZ=Asia/Tehran

# --- Telegram bot ---
BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
# Admin Telegram user IDs (comma-separated): access user list + admin panel
TELEGRAM_ADMIN_USERS=
TELEGRAM_LIVE_SEARCH=yes
# SOCKS/HTTP proxy for Telegram API (only if not using a Cloudflare Worker).
# On Docker: bot uses host network, so 127.0.0.1 is the server's local proxy.
# Example: socks5://127.0.0.1:10810
TELEGRAM_PROXY=
# Cloudflare Worker (or other) reverse proxy for Bot API — use on filtered servers.
# Example: https://tgapi.paanapay.com/bot
TELEGRAM_API_BASE_URL=

# --- Bale bot ---
BALE_BOT_TOKEN=
BALE_ALLOWED_USERS=
BALE_ADMIN_USERS=
BALE_LIVE_SEARCH=yes
BALE_PROXY=

# --- Admin web panel (enamad.paanapay.com) ---
# Login password for the web panel (required to log in).
WEB_ADMIN_PASSWORD=
# Flask session secret; if empty a random one is generated on each restart
# (which logs everyone out on restart). Set a fixed value in production.
WEB_SECRET_KEY=
# Allow live enamad.ir استعلام from the panel (yes/no)
WEB_LIVE_SEARCH=yes

# --- Scheduler (cron syntax: min hour dom mon dow) ---
# New domains once a day at 03:00 (re-scans first N pages; needs captcha OCR)
SCHED_UPDATE_CRON=0 3 * * *
SCHED_UPDATE_PAGES=50
SCHED_UPDATE_WORKERS=1
SCHED_UPDATE_CHUNK_PAGES=10
# Refresh stale domains every 6 hours
SCHED_REFRESH_CRON=0 */6 * * *
SCHED_REFRESH_DAYS=30
SCHED_REFRESH_LIMIT=500
# Parallel threads for refresh (no captcha; 4 is safe for enamad.ir)
SCHED_REFRESH_WORKERS=4
# yes = only domains missing address/phone/email (good after DB import)
SCHED_REFRESH_MISSING_ONLY=no
# Run both jobs once immediately on scheduler start (yes/no)
SCHED_RUN_ON_START=no
