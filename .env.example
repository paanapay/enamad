# Copy to .env and fill in. Used by docker-compose.

# --- MySQL ---
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=enamad

# --- Timezone ---
TZ=Asia/Tehran

# --- Telegram bot ---
BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
# Admin Telegram user IDs (comma-separated): access user list + admin panel
TELEGRAM_ADMIN_USERS=
TELEGRAM_LIVE_SEARCH=yes
# Usually NOT needed on a foreign server; required only behind Iran filtering.
TELEGRAM_PROXY=

# --- Scheduler (cron syntax: min hour dom mon dow) ---
# New domains once a day at 03:00
SCHED_UPDATE_CRON=0 3 * * *
# Refresh stale domains every 6 hours
SCHED_REFRESH_CRON=0 */6 * * *
SCHED_REFRESH_DAYS=30
SCHED_REFRESH_LIMIT=500
# Run both jobs once immediately on scheduler start (yes/no)
SCHED_RUN_ON_START=no
